## Backend environment variables (PaisaBazar)

# Server
PORT=5000

# MongoDB
# Local example:
# MONGODB_URI=mongodb://127.0.0.1:27017/paisabazaar
# Atlas example:
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-host>/<db-name>?retryWrites=true&w=majority

# Cloudinary (for avatars + deposit receipts)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

